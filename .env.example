# Production website URL, without a trailing slash
NEXT_PUBLIC_SITE_URL=https://www.goodgardenfood.com

# Google Analytics 4 Measurement ID, e.g. G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=

# Optional: public business details shown in the contact section
NEXT_PUBLIC_CONTACT_EMAIL=
NEXT_PUBLIC_CONTACT_PHONE=
NEXT_PUBLIC_CONTACT_OFFICE=

# Optional: official social profiles. Leave blank to hide the channel.
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_FACEBOOK_URL=
NEXT_PUBLIC_WHATSAPP_URL=

# Required for contact-form delivery through Resend.
# CONTACT_FROM_EMAIL must be an address on a domain verified in Resend.
RESEND_API_KEY=
CONTACT_TO_EMAIL=
CONTACT_FROM_EMAIL=
